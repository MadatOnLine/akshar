{
  "name": "vision-camera-resize-plugin",
  "version": "3.2.0",
  "summary": "A VisionCamera Frame Processor Plugin for fast and efficient Frame resizing, cropping and pixelformat conversion",
  "homepage": "https://github.com/mrousavy/vision-camera-resize-plugin#readme",
  "license": "MIT",
  "authors": "Marc Rousavy <me@mrousavy.com> (https://github.com/mrousavy)",
  "platforms": {
    "ios": "11.0"
  },
  "source": {
    "git": "https://github.com/mrousavy/vision-camera-resize-plugin.git",
    "tag": "3.2.0"
  },
  "source_files": "ios/**/*.{h,m,mm}",
  "dependencies": {
    "VisionCamera": [],
    "React-Core": [],
    "RCT-Folly": [
      "2024.01.01.00"
    ],
    "glog": [],
    "React-RCTFabric": [],
    "React-Codegen": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/bridging": [],
    "ReactCommon/turbomodule/core": [],
    "React-NativeModulesApple": [],
    "Yoga": [],
    "React-Fabric": [],
    "React-graphics": [],
    "React-utils": [],
    "React-featureflags": [],
    "React-debug": [],
    "React-ImageManager": [],
    "React-rendererdebug": [],
    "DoubleConversion": [],
    "hermes-engine": []
  },
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32",
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -DFOLLY_HAVE_CLOCK_GETTIME=1 -Wno-comma -Wno-shorten-64-to-32"
  }
}
