{
  "name": "@akshar/crypto",
  "version": "1.0.0",
  "description": "Akshar Protocol cryptographic primitives — ECDH, AES-256-GCM, onion routing, face hashing",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./face-hash": {
      "import": "./dist/esm/face-hash.js",
      "require": "./dist/cjs/face-hash.js",
      "types": "./dist/esm/face-hash.d.ts"
    }
  },
  "react-native": {
    "node:crypto": false,
    "crypto": false
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@noble/ciphers": "^0.5.3",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/uuid": "^10.0.0",
    "fast-check": "3.19.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
